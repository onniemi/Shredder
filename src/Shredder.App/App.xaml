<Application x:Class="Shredder.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Shredder.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:BoolToDirTextConverter x:Key="BoolToDirText"/>
            <conv:NullToBoolConverter x:Key="NullToBool"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
