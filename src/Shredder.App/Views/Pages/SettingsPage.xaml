<Page x:Class="Shredder.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="设置">
    <ScrollViewer x:Name="SettingsScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="OnSettingsMouseWheel">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" FontTypography="Title" Text="设置"/>
            <ui:TextBlock Grid.Row="0" Margin="0,32,0,0" FontTypography="Body" Appearance="Tertiary"
                          Text="只保留日常需要调整的选项。安全策略继续由默认配置托管。"/>

            <ui:CardExpander Grid.Row="1" Margin="0,16,0,0" Icon="{ui:SymbolIcon DarkTheme24}" IsExpanded="False"
                             Header="常规">
                <StackPanel>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="主题"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding Theme, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Margin="0,8,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="默认算法"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Algorithms}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding DefaultAlgorithm, Mode=TwoWay}"/>
                        <ui:TextBlock Grid.Column="2" Margin="12,0,0,0" Appearance="Tertiary" VerticalAlignment="Center"
                                      Text="普通文件直接粉碎；系统和禁止路径仍会被拦截。"/>
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Grid.Row="2" Margin="0,12,0,0" Icon="{ui:SymbolIcon DocumentBulletList24}"
                             Header="审计报告">
                <StackPanel>
                    <ui:ToggleSwitch Margin="0,2" IsChecked="{Binding ReportingEnabled, Mode=TwoWay}"
                                     Content="生成粉碎报告"/>
                    <Grid Margin="0,8,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="保存位置"/>
                        <ui:TextBox Grid.Column="1" Text="{Binding ReportingOutputDirectory, Mode=TwoWay}"
                                    IsReadOnly="True"
                                    PlaceholderText="data\reports"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="180,4,0,0">
                        <ui:ToggleSwitch Margin="0,0,16,0" IsChecked="{Binding ReportingFormatJson, Mode=TwoWay}"
                                         Content="JSON"/>
                        <ui:ToggleSwitch IsChecked="{Binding ReportingFormatHtml, Mode=TwoWay}"
                                         Content="HTML"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Grid.Row="3" Margin="0,12,0,0" Icon="{ui:SymbolIcon AppFolder24}"
                             Header="右键菜单" IsExpanded="False">
                <StackPanel>
                    <ui:TextBlock FontTypography="Body" Appearance="Tertiary" TextWrapping="Wrap"
                                  Text="把「粉碎一切」加入文件和文件夹右键菜单。右键选择文件或文件夹后会打开软件，并自动加入粉碎列表。仅写入当前用户配置。"/>
                    <Grid Margin="0,10,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="状态"/>
                        <ui:TextBlock Grid.Column="1" VerticalAlignment="Center"
                                      Text="{Binding ShellMenuStateLabel}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:Button Content="安装" Appearance="Primary"
                                   Icon="{ui:SymbolIcon Add24}" Click="OnInstallShellMenu"/>
                        <ui:Button Content="卸载" Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Delete24}" Click="OnUninstallShellMenu"/>
                        <ui:Button Content="刷新" Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefreshShellMenu"/>
                        <ui:TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Appearance="Tertiary"
                                      Text="{Binding ShellMenuStatus}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <StackPanel Grid.Row="4" Margin="0,20,0,16" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:TextBlock Margin="0,0,16,0" VerticalAlignment="Center" Appearance="Tertiary"
                              Text="{Binding SaveStatus}"/>
                <ui:Button Content="保存" Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                           Click="OnSaveClick"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
