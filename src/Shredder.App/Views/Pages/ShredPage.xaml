<Page x:Class="Shredder.App.Views.Pages.ShredPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Shredder.App.ViewModels"
      Title="粉碎">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" FontTypography="Title" Text="文件 / 目录粉碎"/>
        <ui:TextBlock Grid.Row="0" Margin="0,32,0,0"
                      FontTypography="Body"
                      Appearance="Tertiary"
                      Text="拖入文件或目录，选择算法后开始；操作不可逆。"/>

        <!-- 拖放区 -->
        <Border Grid.Row="1" Margin="0,16,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="20"
                AllowDrop="True"
                DragEnter="OnDragEnter" Drop="OnDrop">
            <StackPanel>
                <ui:TextBlock FontTypography="BodyStrong" HorizontalAlignment="Center"
                              Text="将文件 / 目录拖到这里，或点击下方「添加…」"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <ui:Button Content="添加文件…" Icon="{ui:SymbolIcon Add24}" Click="OnAddFilesClick"/>
                    <ui:Button Content="添加目录…" Icon="{ui:SymbolIcon FolderAdd24}" Margin="8,0,0,0" Click="OnAddFolderClick"/>
                    <ui:Button Content="清空列表" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0" Click="OnClearClick"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 队列 -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6">
            <ListView ItemsSource="{Binding Jobs}" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="路径" Width="320" DisplayMemberBinding="{Binding Path}"/>
                        <GridViewColumn Header="类型" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsDirectory, Converter={StaticResource BoolToDirText}, FallbackValue=文件}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="大小" Width="100" DisplayMemberBinding="{Binding DisplaySize}"/>
                        <GridViewColumn Header="算法" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.Algorithms, RelativeSource={RelativeSource AncestorType=Page}}"
                                              SelectedItem="{Binding Algorithm, Mode=TwoWay}"
                                              DisplayMemberPath="Name"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="状态" Width="100" DisplayMemberBinding="{Binding Status}"/>
                        <GridViewColumn Header="错误" Width="200" DisplayMemberBinding="{Binding ErrorMessage}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- 默认算法 + 进度 -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Text="默认算法："/>
            <ComboBox Grid.Column="1" Margin="8,0,0,0"
                      ItemsSource="{Binding Algorithms}"
                      SelectedItem="{Binding SelectedAlgorithm, Mode=TwoWay}"
                      DisplayMemberPath="Name"/>
            <ui:TextBlock Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center"
                          Appearance="Tertiary"
                          Text="{Binding ProgressText}"/>
            <ui:Button Grid.Column="3" Content="打开最近报告" Icon="{ui:SymbolIcon DocumentBulletList24}"
                       Margin="8,0,0,0"
                       IsEnabled="{Binding LastReportPath, Converter={StaticResource NullToBool}}"
                       Click="OnOpenLastReportClick"/>
            <ui:Button Grid.Column="4" Content="报告文件夹" Icon="{ui:SymbolIcon Folder24}"
                       Margin="8,0,0,0"
                       Click="OnOpenReportsFolderClick"/>
        </Grid>

        <!-- 操作 + 进度条 -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                <ui:Button Content="开始粉碎" Appearance="Danger" Icon="{ui:SymbolIcon Delete24}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                           Click="OnStartClick"/>
                <ui:Button Content="取消" Margin="8,0,0,0"
                           IsEnabled="{Binding IsBusy}"
                           Click="OnCancelClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
