<Page x:Class="Shredder.App.Views.Pages.FreeSpacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="空闲空间擦除">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" FontTypography="Title" Text="空闲空间擦除"/>
        <ui:TextBlock Grid.Row="0" Margin="0,32,0,0" FontTypography="Body" Appearance="Tertiary"
                      TextWrapping="Wrap"
                      Text="向所选分区的空闲扇区写入随机和清零数据，覆盖已删除文件的残留。SSD 会按配置走 TRIM 或回退方案。"/>

        <ui:InfoBar Grid.Row="1" Margin="0,16,0,0" Severity="Warning" IsOpen="True" IsClosable="False"
                    Title="耗时提示"
                    Message="该操作会持续写满分区到几乎没有空闲，可能耗时数分钟到数小时；请确认电源与系统稳定。"/>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Text="目标分区："/>
            <ComboBox Grid.Column="1" Margin="8,0,0,0"
                      ItemsSource="{Binding Drives}"
                      SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                      DisplayMemberPath="Name"/>
            <ui:Button Grid.Column="2" Margin="8,0,0,0" Content="刷新" Icon="{ui:SymbolIcon ArrowSync24}"
                       Click="OnRefreshClick"/>
        </Grid>

        <Border Grid.Row="3" Margin="0,16,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="16">
            <StackPanel>
                <ui:TextBlock FontTypography="BodyStrong" Text="选中分区信息"/>
                <Grid Margin="0,8,0,0" DataContext="{Binding SelectedDrive}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="名称"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name, FallbackValue=-}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="文件系统"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DriveFormat, FallbackValue=-}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="总容量"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalSize, FallbackValue=-}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="可用空间"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AvailableFreeSpace, FallbackValue=-}"/>
                </Grid>
            </StackPanel>
        </Border>

        <ui:TextBlock Grid.Row="4" Margin="0,12,0,0" Appearance="Tertiary"
                      Text="{Binding ProgressText}"/>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                <ui:Button Content="开始擦除" Appearance="Caution" Icon="{ui:SymbolIcon EraserSegment24}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                           Click="OnWipeClick"/>
                <ui:Button Content="取消" Margin="8,0,0,0"
                           IsEnabled="{Binding IsBusy}"
                           Click="OnCancelClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
