<Page x:Class="Shredder.App.Views.Pages.RecycleBinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="回收站">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" FontTypography="Title" Text="安全清空回收站"/>
        <ui:TextBlock Grid.Row="0" Margin="0,32,0,0" FontTypography="Body" Appearance="Tertiary"
                      TextWrapping="Wrap"
                      Text="对所有固定盘的 $Recycle.Bin 先粉碎数据，再调用 Shell32 清空元数据。"/>

        <ui:InfoBar Grid.Row="1" Margin="0,16,0,0" Severity="Informational" IsOpen="True" IsClosable="False"
                    Title="操作说明"
                    Message="该操作会枚举所有就绪的固定盘，按当前默认算法粉碎回收站中的文件，然后调用系统接口清空，不会动其它文件。"/>

        <Border Grid.Row="2" Margin="0,16,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="16">
            <StackPanel>
                <ui:TextBlock FontTypography="BodyStrong" Text="当前状态"/>
                <ui:TextBlock Margin="0,4,0,0" FontTypography="Body"
                              Text="{Binding StatusText}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"/>

        <ui:TextBlock Grid.Row="4" Margin="0,12,0,0" Appearance="Tertiary"
                      Text="{Binding ProgressText}"/>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                <ui:Button Content="清空回收站" Appearance="Danger" Icon="{ui:SymbolIcon Delete24}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                           Click="OnEmptyClick"/>
                <ui:Button Content="取消" Margin="8,0,0,0"
                           IsEnabled="{Binding IsBusy}"
                           Click="OnCancelClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
