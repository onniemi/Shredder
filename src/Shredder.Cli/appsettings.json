{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System": "Warning",
        "Shredder": "Information"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  },
  "Shredder": {
    "Io": {
      "BufferSizeBytes": 4194304,
      "UseUnbufferedIo": true,
      "FlushEveryNBuffers": 0,
      "MaxConcurrentFiles": 1,
      "ProgressReportIntervalMs": 200
    },
    "Safety": {
      "ForbiddenPaths": [
        "%WINDIR%",
        "%ProgramFiles%",
        "%ProgramFiles(x86)%",
        "%ProgramData%\\Microsoft",
        "%SystemRoot%\\System32",
        "%SystemDrive%\\Boot",
        "%SystemDrive%\\System Volume Information",
        "%SystemDrive%\\Recovery"
      ],
      "WarnPaths": [
        "%USERPROFILE%",
        "%USERPROFILE%\\Documents",
        "%USERPROFILE%\\Desktop",
        "%LOCALAPPDATA%",
        "%APPDATA%"
      ],
      "AllowPaths": [],
      "RejectReparsePoints": true,
      "ResolveReparseTargets": true,
      "ShredAlternateDataStreams": true,
      "MftResidentInflateThresholdBytes": 700,
      "MftResidentInflateTargetBytes": 4096,
      "UseRestartManagerForLockedFiles": true,
      "AllowScheduleOnRebootDelete": true,
      "DetectSolidStateDrives": true,
      "PreferTrimForSsd": true
    },
    "RecycleBin": {
      "ProcessAllDrives": true,
      "OverwriteContents": true,
      "CallShellEmptyAfterShred": true
    },
    "FreeSpace": {
      "BlockSizeBytes": 67108864,
      "MinimumFreeBytesBuffer": 268435456,
      "ScrubMftSlack": true,
      "DisableOnSsd": true,
      "FallbackToTrimOnSsd": true
    },
    "Algorithm": {
      "Default": "Purge-3Pass",
      "SsdDefault": "CryptoErase"
    },
    "Ui": {
      "ConfirmationKeyword": "粉碎",
      "ConfirmationCooldownSeconds": 0,
      "Theme": "System"
    },
    "Reporting": {
      "Enabled": true,
      "OutputDirectory": "%LOCALAPPDATA%\\Shredder\\Reports",
      "FormatJson": true,
      "FormatHtml": false,
      "AutoOpen": false
    },
    "Logging": {
      "RecordRawPaths": false,
      "OutputDirectory": "%LOCALAPPDATA%\\Shredder\\Logs",
      "FileSizeLimitBytes": 10485760,
      "RetainedFileCountLimit": 14,
      "FileSinkEnabled": true
    }
  }
}
